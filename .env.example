# ── videocalltizen — variables d'environnement (copier en .env, NON commité) ──
#
# Source de vérité UNIQUE des secrets. Le repo ne contient AUCUN secret réel :
# livekit-server et l'ingress lisent leurs clés ICI (via LIVEKIT_KEYS /
# INGRESS_CONFIG_BODY dans docker-compose.yml).
#
# ⚠️ Les valeurs LiveKit/TURN ci-dessous sont des valeurs DEV publiques (jetables),
#    pratiques en local. Pour TOUTE instance exposée : ./scripts/gen-keys.sh

# --- LiveKit (clé/secret API ; régénérer pour la prod) ---
LIVEKIT_API_KEY=APIVisioDev
LIVEKIT_API_SECRET=VkS3cret_dev_0123456789abcdef0123456789

# URLs internes au réseau Docker 'visio'
LIVEKIT_WS_URL=ws://livekit:7880
LIVEKIT_API_URL=http://livekit:7880

# URL publiée vers le navigateur de l'interlocuteur / la TV (hôte local par défaut)
LIVEKIT_PUBLIC_WS_URL=ws://localhost:7880

# Salle et identités de référence
ROOM_NAME=salon
CAMERA_IDENTITY=camera-salon

# --- go2rtc ---
GO2RTC_API_URL=http://go2rtc:1984
GO2RTC_STREAM=salon

# --- TURN (prod uniquement, profil 'turn') ---
TURN_REALM=visio.example.com
TURN_SHARED_SECRET=turnSharedSecret_dev_change_me_in_prod_0123

# --- Eufy (profil 'eufy' UNIQUEMENT — touche la vraie caméra, à brancher en dernier) ---
# Instance DÉDIÉE 'eufy-visio' (trusted device distinct du Gardien). Ne PAS réutiliser eufy-mcp.
EUFY_USERNAME=
EUFY_PASSWORD=
EUFY_COUNTRY=CH
EUFY_WS_PORT=3010
EUFY_TRUSTED_DEVICE_NAME=eufy-visio
# Image eufy-security-ws (officielle par défaut ; surcharger si vous utilisez un build local)
EUFY_WS_IMAGE=bropat/eufy-security-ws:latest
# Numéro de série de la S350 (rempli en phase d'intégration Eufy)
EUFY_CAMERA_SERIAL=

# --- SmartThings (optionnel : réveil TV / prise en main de l'écran — voir docs) ---
SMARTTHINGS_TOKEN=
SMARTTHINGS_DEVICE_ID=
